{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pizza",
  "compatibility_date": "2026-05-15",
  "observability": {
    "enabled": true
  },
  "main": "src/worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "MENU",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID",
      "preview_id": "REPLACE_WITH_KV_PREVIEW_NAMESPACE_ID"
    }
  ]
}
